{
    "name": "mini-diffs",
    "displayName": "Mini Diffs",
    "description": "Similar to mini diff function of Sublime text editor",
    "version": "0.3.11",
    "publisher": "pit00",
    "repository": "https://github.com/pit00/mini-diff",
    "icon": "img/icon.png",
    "engines": {
        "vscode": "^1.68.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/main",
    "contributes": {
        "commands": [
            {
                "command": "miniDiff.goToPrevChange",
                "title": "Mini Diffs: go to prev change"
            },
            {
                "command": "miniDiff.goToNextChange",
                "title": "Mini Diffs: go to next change"
            },
            {
                "command": "miniDiff.clearDiffs",
                "title": "Mini Diffs: clear current files diffs"
            }
        ],
        "configuration": {
            "title": "Mini Diff",
            "type": "object",
            "properties": {
                "miniDiff.wholeLine": {
                    "type": "boolean",
                    "default": true,
                    "description": "highlight multi-line block"
                },
                "miniDiff.clearOnSave": {
                    "type": "boolean",
                    "default": false,
                    "description": "clear decorations on file save"
                },
                "miniDiff.showInGutter": {
                    "type": "boolean",
                    "default": true,
                    "description": "show changes in gutter"
                },
                "miniDiff.showInOverView": {
                    "type": "boolean",
                    "default": true,
                    "description": "show changes in overview"
                },
                "miniDiff.showDiffOutput": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "show changes diff in output panel"
                },
                "miniDiff.debounceTime": {
                    "type": "number",
                    "default": 500,
                    "minimum": 500,
                    "markdownDescription": "ms to wait before checking for changes\n\n(increase the time if the editor became sluggish)"
                },
                "miniDiff.gitPath": {
                    "type": "string",
                    "default": "git",
                    "markdownDescription": "global git path, [git-installation](https://git-scm.com/book/en/v2/Getting-Started-Installing-Git)."
                },
                "miniDiff.terminalShellPath": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "default": null,
                    "description": "custom terminal shell path"
                },
                "miniDiff.disableInGit": {
                    "type": "boolean",
                    "default": false,
                    "description": "Disable for files inside Git repositories"
                },
                "miniDiff.schemeTypesIgnore": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "uniqueItems": true,
                    "description": "ignored files schemes"
                },
                "miniDiff.styles": {
                    "type": "object",
                    "default": {
                        "overview": {
                            "position": 2,
                            "opacity": 0.75,
                            "add": "#2faf64",
                            "change": "#FFCE57",
                            "del": "#a31515"
                        },
                        "gutter": {
                            "size": "auto",
                            "add": "#2faf64",
                            "change": "#FFCE57",
                            "del": "#a31515"
                        }
                    },
                    "description": "decoration styles"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run esbuild-base -- --pure:console.log --minify",
        "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/main.js --external:vscode --format=cjs --platform=node",
        "esbuild": "npm run esbuild-base -- --sourcemap",
        "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
        "watch": "npm run esbuild"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.1",
        "@types/node": "^18.14.1",
        "@types/vscode": "^1.68.0",
        "esbuild": "^0.17.10",
        "typescript": "^4.9.5"
    },
    "dependencies": {
        "execa": "^7.0.0",
        "fs-extra": "^11.1.0",
        "hex-to-rgba": "^2.0.1",
        "p-debounce": "^4.0.0",
        "parse-git-diff": "^0.0.7",
        "tmp-promise": "^3.0.3"
    }
}
